---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => b.data.order - a.data.order
);

// Fixed display order of the categories.
const GROUP_ORDER = [
  'Robotics',
  'Mechatronics',
  'Backend Web Development',
  'Other',
];

const groups = GROUP_ORDER.map((name) => ({
  name,
  projects: projects.filter((p) => p.data.group === name),
})).filter((g) => g.projects.length > 0);

// All unique tags, sorted, for the filter bar.
const allTags = [...new Set(projects.flatMap((p) => p.data.tags))].sort((a, b) =>
  a.localeCompare(b)
);
---

<Layout title="Projects — Hassan Umari" description="Robotics, embedded systems, and software projects by Hassan Umari.">
  <h1>Projects</h1>
  <p class="muted intro-line">
    A selection of things I've built — robotics, embedded systems, web apps, and
    research.
  </p>

  <div class="filter-bar" id="filter-bar">
    <button type="button" class="filter is-active" data-tag="">All</button>
    {
      allTags.map((t) => (
        <button type="button" class="filter" data-tag={t}>
          {t}
        </button>
      ))
    }
  </div>

  <p class="no-results" id="no-results" hidden>No projects match that tag.</p>

  {
    groups.map((group) => (
      <section class="group" data-group={group.name}>
        <h2 class="group-title">{group.name}</h2>
        <ul class="project-list">
          {group.projects.map((p) => (
            <li class="card" data-tags={p.data.tags.join('|')}>
              <a href={`/projects/${p.id}`} class="card-link">
                {p.data.image && (
                  <div class:list={['thumb', { 'thumb-transparent': p.data.transparentThumb }]}>
                    <img src={p.data.image} alt={p.data.title} loading="lazy" />
                  </div>
                )}
                <div class="card-body">
                  <h3 class="card-title">
                    {p.data.title}
                    {p.data.wip && <span class="wip">WIP</span>}
                  </h3>
                  <p class="card-desc">{p.data.description}</p>
                  <div class="tag-row">
                    {p.data.tags.slice(0, 5).map((t) => (
                      <span class="tag">{t}</span>
                    ))}
                  </div>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Layout>

<script>
  const bar = document.getElementById('filter-bar');
  const noResults = document.getElementById('no-results');
  const cards = Array.from(document.querySelectorAll<HTMLElement>('.card'));
  const sections = Array.from(document.querySelectorAll<HTMLElement>('.group'));
  const allBtn = bar?.querySelector<HTMLElement>('.filter[data-tag=""]');

  // Selected tags. Empty set means "All" (show everything).
  const selected = new Set<string>();

  function apply() {
    // "All" is active only when no specific tags are selected.
    allBtn?.classList.toggle('is-active', selected.size === 0);
    bar?.querySelectorAll<HTMLElement>('.filter[data-tag]').forEach((b) => {
      const tag = b.dataset.tag ?? '';
      if (tag) b.classList.toggle('is-active', selected.has(tag));
    });

    let anyVisible = false;
    cards.forEach((card) => {
      const tags = (card.dataset.tags ?? '').split('|');
      // Show if nothing is selected, or the card matches any selected tag (OR).
      const show =
        selected.size === 0 || tags.some((t) => selected.has(t));
      card.hidden = !show;
      if (show) anyVisible = true;
    });

    // Hide category sections that have no visible cards.
    sections.forEach((section) => {
      section.hidden = !section.querySelector('.card:not([hidden])');
    });

    if (noResults) noResults.hidden = anyVisible;
  }

  bar?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.filter');
    if (!btn) return;

    const tag = btn.dataset.tag ?? '';
    if (tag === '') {
      selected.clear(); // "All" resets everything.
    } else if (selected.has(tag)) {
      selected.delete(tag);
    } else {
      selected.add(tag);
    }

    apply();
  });
</script>

<style>
  .intro-line {
    margin-top: -0.25rem;
  }
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin: 1.5rem 0 0;
  }
  .filter {
    font: inherit;
    font-size: 0.82rem;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--bg);
    color: var(--text-muted);
    cursor: pointer;
    transition: border-color 0.15s ease, color 0.15s ease,
      background 0.15s ease;
  }
  .filter:hover {
    border-color: var(--text-muted);
    color: var(--text);
  }
  .filter.is-active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }
  .no-results {
    color: var(--text-muted);
    margin-top: 1.5rem;
  }
  .group {
    margin-top: 2.5rem;
  }
  .group-title {
    font-size: 1.35rem;
    margin: 0 0 0.25rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--border);
  }
  .project-list {
    list-style: none;
    padding: 0;
    margin: 1.25rem 0 0;
    display: grid;
    gap: 1.25rem;
  }
  .card {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg);
    transition: border-color 0.25s ease, transform 0.25s cubic-bezier(0.22, 1, 0.36, 1),
      box-shadow 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .card:hover {
    border-color: var(--text-muted);
    transform: translateY(-4px);
    box-shadow: 0 8px 20px -6px rgba(0, 0, 0, 0.18);
  }
  .card-link {
    display: flex;
    gap: 1.1rem;
    color: var(--text);
    align-items: stretch;
  }
  .card-link:hover {
    text-decoration: none;
  }
  .thumb {
    flex-shrink: 0;
    width: 160px;
    background: var(--surface);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .thumb-transparent {
    background: transparent;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .thumb-transparent img {
    object-fit: contain;
    padding: 1rem;
  }
  .card-body {
    padding: 1rem 1.1rem 1rem 0;
    min-width: 0;
  }
  .card-title {
    margin: 0.15rem 0 0.35rem;
    font-size: 1.15rem;
  }
  .card:hover .card-title {
    color: var(--accent);
  }
  .card-desc {
    color: var(--text-muted);
    font-size: 0.92rem;
    margin: 0 0 0.7rem;
  }
  .wip {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    vertical-align: middle;
    margin-left: 0.5rem;
    padding: 0.1rem 0.4rem;
    border-radius: 5px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
  @media (max-width: 540px) {
    .card-link {
      flex-direction: column;
    }
    .thumb {
      width: 100%;
      height: 170px;
    }
    .card-body {
      padding: 0 1.1rem 1.1rem;
    }
  }
</style>
