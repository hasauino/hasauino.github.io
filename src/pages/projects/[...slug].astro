---
import Layout from '../../layouts/Layout.astro';
import Model3D from '../../components/Model3D.astro';
import Carousel from '../../components/Carousel.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const {
  title,
  description,
  tags,
  github,
  demo,
  paper,
  youtube,
  model,
  modelHeight,
  modelDistance,
  modelFov,
  wip,
} = project.data;
---

<Layout title={`${title} — Hassan Umari`} description={description}>
  <p class="back"><a href="/projects">← Projects</a></p>

  <header class="proj-header">
    <h1>{title} {wip && <span class="wip">WIP</span>}</h1>
    <p class="muted subtitle">{description}</p>

    {
      tags.length > 0 && (
        <div class="tag-row">
          {tags.map((t) => (
            <span class="tag">{t}</span>
          ))}
        </div>
      )
    }

    {
      (github || demo || paper) && (
        <div class="links">
          {github && (
            <a class="btn" href={github} target="_blank" rel="noopener noreferrer">
              GitHub
            </a>
          )}
          {demo && (
            <a class="btn btn--primary" href={demo} target="_blank" rel="noopener noreferrer">
              Live demo
            </a>
          )}
          {paper && (
            <a class="btn" href={paper} target="_blank" rel="noopener noreferrer">
              Paper
            </a>
          )}
        </div>
      )
    }
  </header>

  {
    youtube && (
      <div class="video">
        <iframe
          src={`https://www.youtube.com/embed/${youtube}`}
          title={`${title} video`}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        />
      </div>
    )
  }

  <article class="prose">
    <Content components={{ Model3D, Carousel }} />
  </article>

  {
    model && (
      <section class="cad">
        <h2>3D Model</h2>
        <Model3D
          src={model}
          height={modelHeight}
          cameraDistance={modelDistance}
          fov={modelFov}
        />
      </section>
    )
  }
</Layout>

<style>
  .back {
    font-size: 0.9rem;
    margin: 0.5rem 0 1.5rem;
  }
  .proj-header h1 {
    margin-bottom: 0.4rem;
  }
  .subtitle {
    font-size: 1.05rem;
    margin: 0 0 0.9rem;
  }
  .wip {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    vertical-align: middle;
    padding: 0.15rem 0.45rem;
    border-radius: 5px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text-muted);
  }
  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 1.1rem;
  }
  .video {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    margin: 2rem 0 0.5rem;
    border-radius: var(--radius);
    overflow: hidden;
    border: 1px solid var(--border);
    background: #000;
  }
  .video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
  .prose {
    margin-top: 1.5rem;
  }
  .prose :global(h2) {
    font-size: 1.3rem;
  }
</style>
